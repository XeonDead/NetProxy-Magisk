#!/system/bin/sh
# NetProxy Command Line Tool

set -e
set -u

readonly MODDIR="$(cd "$(dirname "$0")/.." && pwd)"
readonly SCRIPTS_DIR="$MODDIR/scripts"
readonly CONFIG_DIR="$MODDIR/config"
readonly MODULE_CONF="$CONFIG_DIR/module.conf"
readonly TPROXY_DIR="$CONFIG_DIR/tproxy"
readonly TPROXY_CONF="$TPROXY_DIR/tproxy.conf"
readonly SINGBOX_DIR="$CONFIG_DIR/singbox"
readonly SINGBOX_OUTBOUNDS_DIR="$SINGBOX_DIR/outbounds"
readonly DEFAULT_NODES_DIR="$SINGBOX_OUTBOUNDS_DIR/default"
readonly RUNTIME_DIR="$SINGBOX_DIR/runtime"
readonly CLI_NODE_SCAN_FILE="$RUNTIME_DIR/cli_nodes.tsv"
readonly LOG_DIR="$MODDIR/logs"
readonly SERVICE_LOG="$LOG_DIR/service.log"
readonly CORE_LOG="$LOG_DIR/sing-box.log"
readonly SUB_LOG="$LOG_DIR/subscription.log"

readonly SING_BOX_BIN="$MODDIR/bin/sing-box"
readonly PROXYLINK_BIN="$MODDIR/bin/proxylink"
readonly SERVICE_SCRIPT="$SCRIPTS_DIR/core/service.sh"
readonly SWITCH_SCRIPT="$SCRIPTS_DIR/core/switch.sh"
readonly SUB_SCRIPT="$SCRIPTS_DIR/core/subscription.sh"
readonly TPROXY_SCRIPT="$SCRIPTS_DIR/network/tproxy.sh"

readonly CLASH_API="127.0.0.1:9999"
readonly CLASH_SECRET="singbox"
readonly SELECTOR_GROUP="proxy"
readonly DELAY_URL="https://www.gstatic.com/generate_204"

. "$MODDIR/scripts/utils/common.sh"
. "$MODDIR/scripts/utils/config.sh"
. "$MODDIR/scripts/utils/api.sh"
. "$MODDIR/scripts/utils/nodes.sh"

if [ -t 1 ]; then
  readonly RED="$(printf '\033[0;31m')"
  readonly GREEN="$(printf '\033[0;32m')"
  readonly YELLOW="$(printf '\033[1;33m')"
  readonly BLUE="$(printf '\033[0;34m')"
  readonly NC="$(printf '\033[0m')"
else
  readonly RED=""
  readonly GREEN=""
  readonly YELLOW=""
  readonly BLUE=""
  readonly NC=""
fi

#######################################
# Terminal Output
#######################################
info() {
  printf "%s[Information]%s %s\n" "$GREEN" "$NC" "$1"
}

warn() {
  printf "%s[Warning]%s %s\n" "$YELLOW" "$NC" "$1"
}

die_cli() {
  printf "%s[Error]%s %s\n" "$RED" "$NC" "$1" >&2
  exit 1
}

section() {
  printf "\n%s%s%s\n" "$BLUE" "$1" "$NC"
}

#######################################
# Basic support
#######################################
is_running() {
  [ -n "$(get_pid "$SING_BOX_BIN")" ]
}

ensure_cli_dirs() {
  ensure_dir "$LOG_DIR" "Could not create log directory: $LOG_DIR"
  ensure_dir "$DEFAULT_NODES_DIR" "Could not create default node directory: $DEFAULT_NODES_DIR"
  ensure_dir "$RUNTIME_DIR" "Could not create running-time directory: $RUNTIME_DIR"
}

prepare_node_scan() {
  local current_config

  ensure_cli_dirs
  current_config="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"
  scan_all_nodes "$SINGBOX_OUTBOUNDS_DIR" "$current_config" "$CLI_NODE_SCAN_FILE"
}

print_node_line() {
  local path="$1"
  local name="$2"
  local tag="$3"
  local source="$4"
  local is_current="$5"
  local mark=" "

  [ "$is_current" = "1" ] && mark="*"

  if [ -n "$tag" ]; then
    printf "  %s %-24s %s\n" "$mark" "$name" "$tag"
  else
    printf "  %s %s\n" "$mark" "$name"
  fi
}

show_service_help() {
  cat << EOF
Usage:
  cli service status                  View Service Status
  cli service start                   Start-up services
  cli service stop                    Stop Service
  cli service restart                 Restart Service
  cli service logs [service|core|sub] [Lines]
                                      View Log
EOF
}

show_node_help() {
  cat << EOF
Usage:
  cli node list                       List all nodes
  cli node current                    View the current node
  cli node use <Name|Label|Path>       Toggle Node
  cli node add <Node Link>             Add a single node
  cli node import <Documentation>              Import node file or Clash YAML
  cli node export <Node file>          Will sing-box Node to Link
  cli node show <Name|Label|Path>      View Node Configuration
  cli node remove <Name|Label|Path>    Delete Node
  cli node delay [Name|Label|all]      Test node delay
EOF
}

show_mode_help() {
  cat << EOF
Usage:
  cli mode                            View Current Mode
  cli mode <rule|global|direct>       Toggle outbound mode
EOF
}

show_sub_help() {
  cat << EOF
Usage:
  cli sub list                        List Subscriptions
  cli sub add <Name> <Link>           Add Subscription
  cli sub update <Name>               Update specified subscriptions
  cli sub update-all                  Update All Subscriptions
  cli sub remove <Name>               Delete Subscriptions
EOF
}

show_api_help() {
  cat << EOF
Usage:
  cli api groups                      View Agent Group
  cli api conns                       View Connections
  cli api close <ConnectionID>              Close the specified connection
  cli api close-all                   Close All Connections
  cli api ui                          View controller and panel address
EOF
}

show_app_help() {
  cat << EOF
Usage:
  cli app list                        View split application proxy configuration
  cli app mode <blacklist|whitelist>  Set SubApplication Mode
  cli app add <Package name>                  Add Application
  cli app remove <Package name>               Remove Application
  cli app enable                      Enable sub-application agent
  cli app disable                     Disable branch application agent
EOF
}

show_tproxy_help() {
  cat << EOF
Usage:
  cli tproxy status                   View transparent proxy configuration
  cli tproxy reload                   Loading Transparency Proxy Rules
  cli tproxy quic <on|off>            Switch QUIC Block
  cli tproxy cnip <on|off>            Switch China IP Go around.
EOF
}

#######################################
# service Command
#######################################
cmd_service_status() {
  local pid current mode version api_mode tcp_port udp_port dns_port

  section "Service Status"
  pid="$(get_pid "$SING_BOX_BIN")"

  if [ -n "$pid" ]; then
    printf "Active Status: %sRunning%s\n" "$GREEN" "$NC"
    printf "Process PID: %s\n" "$pid"
    printf "Run Time: %s sec\n" "$(get_process_uptime "$pid")"
  else
    printf "Active Status: %sNot running%s\n" "$RED" "$NC"
  fi

  current="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"
  mode="$(read_conf "$MODULE_CONF" "OUTBOUND_MODE" "rule")"
  tcp_port="$(read_conf "$TPROXY_CONF" "PROXY_TCP_PORT" "-")"
  udp_port="$(read_conf "$TPROXY_CONF" "PROXY_UDP_PORT" "-")"
  dns_port="$(read_conf "$TPROXY_CONF" "DNS_PORT" "-")"

  [ -n "$current" ] && printf "Current Node: %s\n" "$(basename "$current")"
  printf "Outbound Mode: %s\n" "$mode"
  printf "Transparent proxy port: TCP=%s UDP=%s DNS=%s\n" "$tcp_port" "$udp_port" "$dns_port"

  if [ -n "$pid" ]; then
    api_mode="$(api_get_mode 2> /dev/null || true)"
    [ -n "$api_mode" ] && printf "Run Mode: %s\n" "$api_mode"
  fi

  if [ -x "$SING_BOX_BIN" ]; then
    version="$("$SING_BOX_BIN" version 2> /dev/null | head -1 || true)"
    [ -n "$version" ] && printf "kernel version: %s\n" "$version"
  fi
}

cmd_service_start() {
  ensure_cli_dirs
  info "Starting service..."
  sh "$SERVICE_SCRIPT" start
}

cmd_service_stop() {
  ensure_cli_dirs
  info "Stopping service..."
  sh "$SERVICE_SCRIPT" stop
}

cmd_service_restart() {
  ensure_cli_dirs
  info "Restarting service..."
  sh "$SERVICE_SCRIPT" restart
}

cmd_service_logs() {
  local target="${1:-service}"
  local lines="${2:-80}"
  local file

  case "$target" in
    service) file="$SERVICE_LOG" ;;
    core | sing-box | singbox) file="$CORE_LOG" ;;
    sub | subscription) file="$SUB_LOG" ;;
    *) die_cli "Unknown Log Type: $target" ;;
  esac

  [ -f "$file" ] || die_cli "Log file does not exist: $file"
  tail -n "$lines" "$file"
}

cmd_service() {
  local subcmd="${1:-status}"
  shift 2> /dev/null || true

  case "$subcmd" in
    status) cmd_service_status "$@" ;;
    start) cmd_service_start "$@" ;;
    stop) cmd_service_stop "$@" ;;
    restart) cmd_service_restart "$@" ;;
    logs) cmd_service_logs "$@" ;;
    help | -h | --help) show_service_help ;;
    *) die_cli "Use error, use cli service help View Help" ;;
  esac
}

#######################################
# node Command
#######################################
cmd_node_list() {
  local path name tag source is_current current_source="" count=0

  prepare_node_scan

  while IFS="$NODE_RECORD_DELIM" read -r path name tag source is_current; do
    if [ "$source" != "$current_source" ]; then
      section "$source"
      current_source="$source"
    fi
    print_node_line "$path" "$name" "$tag" "$source" "$is_current"
    count=$((count + 1))
  done < "$CLI_NODE_SCAN_FILE"

  [ "$count" -gt 0 ] || printf "No nodes for now\n"
}

cmd_node_current() {
  local current tag

  current="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"
  if [ -z "$current" ]; then
    printf "No node is currently set\n"
    return 0
  fi

  tag="$(detect_outbound_tag "$current" || true)"

  section "Current Node"
  printf "Filename: %s\n" "$(basename "$current")"
  [ -n "$tag" ] && printf "Label: %s\n" "$tag"
  printf "Path: %s\n" "$current"
}

cmd_node_use() {
  local query="${1:-}"
  local node

  [ -n "$query" ] || die_cli "Usage: cli node use <Name|Label|Path>"
  prepare_node_scan
  node="$(resolve_node_from_scan "$CLI_NODE_SCAN_FILE" "$query")"
  info "Switching nodes: $(basename "$node")"
  sh "$SWITCH_SCRIPT" config "$node"
}

cmd_node_add() {
  local link="${1:-}"

  [ -n "$link" ] || die_cli "Usage: cli node add <Node Link>"
  info "Importing nodes..."
  sh "$SUB_SCRIPT" parse "$link" "$DEFAULT_NODES_DIR"
  info "Node import complete"
}

cmd_node_import() {
  local file="${1:-}"

  [ -n "$file" ] || die_cli "Usage: cli node import <Documentation>"
  [ -f "$file" ] || die_cli "File does not exist: $file"
  info "Importing files..."
  sh "$SUB_SCRIPT" file "$file" "$DEFAULT_NODES_DIR"
  info "File import complete"
}

cmd_node_export() {
  local query="${1:-}"
  local node

  [ -n "$query" ] || die_cli "Usage: cli node export <Node file>"
  prepare_node_scan
  if [ -f "$query" ]; then
    node="$query"
  else
    node="$(resolve_node_from_scan "$CLI_NODE_SCAN_FILE" "$query")"
  fi
  sh "$SUB_SCRIPT" convert "$node"
}

cmd_node_show() {
  local query="${1:-}"
  local node

  [ -n "$query" ] || die_cli "Usage: cli node show <Name|Label|Path>"
  prepare_node_scan
  node="$(resolve_node_from_scan "$CLI_NODE_SCAN_FILE" "$query")"
  printf "Documentation: %s\n" "$node"
  printf -- "--------------------------------\n"
  cat "$node"
}

cmd_node_remove() {
  local query="${1:-}"
  local node current

  [ -n "$query" ] || die_cli "Usage: cli node remove <Name|Label|Path>"
  prepare_node_scan
  node="$(resolve_node_from_scan "$CLI_NODE_SCAN_FILE" "$query")"
  current="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"

  [ "$node" != "$current" ] || die_cli "Cannot delete currently in use node"
  rm -f "$node"
  info "Deleted Node: $(basename "$node")"
}

delay_one() {
  local tag="$1"
  local result delay

  result="$(api_test_delay "$tag" "$(api_delay_url)" 5000 2> /dev/null || true)"
  delay="$(printf "%s" "$result" | sed -n 's/.*"delay"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p')"

  if [ -n "$delay" ]; then
    printf "%-24s %s ms\n" "$tag" "$delay"
  else
    printf "%-24s %s\n" "$tag" "Failed"
  fi
}

cmd_node_delay() {
  local query="${1:-}"
  local node tag path name source is_current

  if [ "$query" = "all" ]; then
    prepare_node_scan
    while IFS="$NODE_RECORD_DELIM" read -r path name tag source is_current; do
      [ -n "$tag" ] || continue
      delay_one "$tag"
    done < "$CLI_NODE_SCAN_FILE"
    return 0
  fi

  if [ -n "$query" ]; then
    prepare_node_scan
    if node="$(resolve_node_from_scan "$CLI_NODE_SCAN_FILE" "$query" 2> /dev/null)"; then
      tag="$(detect_outbound_tag "$node" || true)"
    else
      tag="$query"
    fi
  else
    node="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"
    [ -n "$node" ] || die_cli "No node is currently set"
    tag="$(detect_outbound_tag "$node" || true)"
  fi

  [ -n "$tag" ] || die_cli "Could not read node label"
  delay_one "$tag"
}

cmd_node() {
  local subcmd="${1:-list}"
  shift 2> /dev/null || true

  case "$subcmd" in
    list) cmd_node_list "$@" ;;
    current) cmd_node_current "$@" ;;
    use) cmd_node_use "$@" ;;
    add) cmd_node_add "$@" ;;
    import) cmd_node_import "$@" ;;
    export) cmd_node_export "$@" ;;
    show) cmd_node_show "$@" ;;
    remove | rm) cmd_node_remove "$@" ;;
    delay) cmd_node_delay "$@" ;;
    help | -h | --help) show_node_help ;;
    *) die_cli "Use error, use cli node help View Help" ;;
  esac
}

#######################################
# mode Command
#######################################
cmd_mode() {
  local mode="${1:-}"
  local current api_mode

  if [ -z "$mode" ]; then
    current="$(read_conf "$MODULE_CONF" "OUTBOUND_MODE" "rule")"
    printf "Lasting Mode: %s\n" "$current"
    if is_running; then
      api_mode="$(api_get_mode 2> /dev/null || true)"
      [ -n "$api_mode" ] && printf "Run Mode: %s\n" "$api_mode"
    fi
    return 0
  fi

  case "$mode" in
    rule | global | direct) ;;
    help | -h | --help)
      show_mode_help
      return 0
      ;;
    *)
      die_cli "Unknown mode: $mode"
      ;;
  esac

  sh "$SWITCH_SCRIPT" mode "$mode"
}

#######################################
# sub Command
#######################################
cmd_sub() {
  local subcmd="${1:-list}"
  shift 2> /dev/null || true

  case "$subcmd" in
    list) sh "$SUB_SCRIPT" list ;;
    add) sh "$SUB_SCRIPT" add "${1:-}" "${2:-}" ;;
    update) sh "$SUB_SCRIPT" update "${1:-}" ;;
    update-all) sh "$SUB_SCRIPT" update-all ;;
    remove | rm) sh "$SUB_SCRIPT" remove "${1:-}" ;;
    help | -h | --help) show_sub_help ;;
    *) die_cli "Use error, use cli sub help View Help" ;;
  esac
}

#######################################
# api Command
#######################################
cmd_api_groups() {
  local json now item has_output=0

  json="$(api_get_proxies 2> /dev/null)" || die_cli "Control interface not available, please confirm service is running"
  now="$(api_selector_current "$json" "$(api_selector_group)" || true)"

  section "Agent Group"
  [ -n "$now" ] && printf "%s: %s\n" "$(api_selector_group)" "$now"

  while IFS= read -r item; do
    [ -n "$item" ] || continue
    [ "$item" = "$now" ] && continue
    if [ "$has_output" -eq 0 ]; then
      printf "Selected Nodes:\n"
      has_output=1
    fi
    printf "  - %s\n" "$item"
  done << EOF
$(api_selector_options "$json" "$(api_selector_group)" 2> /dev/null || true)
EOF

  [ "$has_output" -eq 1 ] || printf "No node information available for the time being\n"
}

cmd_api_conns() {
  local json total ids id count=0

  json="$(api_get_connections 2> /dev/null)" || die_cli "Control interface not available, please confirm service is running"
  total="$(printf "%s" "$json" | sed -n 's/.*"downloadTotal"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p')"
  [ -n "$total" ] && printf "Total Downloads: %s bytes\n" "$total"

  ids="$(printf "%s" "$json" | grep -o '"id"[[:space:]]*:[[:space:]]*"[^"]*"' | sed -n 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' || true)"
  if [ -n "$ids" ]; then
    printf "Connection List:\n"
    for id in $ids; do
      printf "  - %s\n" "$id"
      count=$((count + 1))
      [ "$count" -ge 20 ] && break
    done
  else
    printf "%s\n" "$json"
  fi
}

cmd_api_close() {
  local id="${1:-}"

  [ -n "$id" ] || die_cli "Usage: cli api close <ConnectionID>"
  api_close_connection "$id" || die_cli "Could not close connection"
  info "Connection closed: $id"
}

cmd_api_close_all() {
  api_close_all_connections || die_cli "Failed to close all connections"
  info "All connections closed"
}

cmd_api_ui() {
  local ip

  ip="$(detect_primary_ipv4)"
  [ -n "$ip" ] || ip="<EquipmentIP>"

  printf "Control Address: http://%s:9999\n" "$ip"
  printf "Panel Address: http://%s:9999/ui\n" "$ip"
  printf "Key: %s\n" "$(api_secret)"
}

cmd_api() {
  local subcmd="${1:-groups}"
  shift 2> /dev/null || true

  case "$subcmd" in
    groups) cmd_api_groups "$@" ;;
    conns) cmd_api_conns "$@" ;;
    close) cmd_api_close "$@" ;;
    close-all) cmd_api_close_all "$@" ;;
    ui) cmd_api_ui "$@" ;;
    help | -h | --help) show_api_help ;;
    *) die_cli "Use error, use cli api help View Help" ;;
  esac
}

#######################################
# app Command
#######################################
reload_tproxy_if_running() {
  if is_running; then
    info "Reloading transparency proxy rules..."
    sh "$TPROXY_SCRIPT" restart -d "$TPROXY_DIR" > /dev/null 2>&1 || die_cli "Failed to reload transparent proxy rules"
    info "The transparent proxy rule has been reloaded"
  else
    info "The service is not running and the configuration will be effective on the next start"
  fi
}

cmd_app_list() {
  printf "SubApplication Agent: %s\n" "$(read_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "0")"
  printf "Apply Mode: %s\n" "$(read_conf "$TPROXY_CONF" "APP_PROXY_MODE" "blacklist")"
  printf "Proxy List: %s\n" "$(read_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "")"
  printf "Overlist: %s\n" "$(read_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "")"
}

cmd_app_mode() {
  local mode="${1:-}"

  case "$mode" in
    blacklist | whitelist) ;;
    *) die_cli "Usage: cli app mode <blacklist|whitelist>" ;;
  esac

  set_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "1"
  set_conf "$TPROXY_CONF" "APP_PROXY_MODE" "$(quote_conf "$mode")"
  info "Apply mode set as: $mode"
  reload_tproxy_if_running
}

cmd_app_add() {
  local package="${1:-}"
  local mode current_list new_list

  [ -n "$package" ] || die_cli "Usage: cli app add <Package name>"

  set_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "1"
  mode="$(read_conf "$TPROXY_CONF" "APP_PROXY_MODE" "blacklist")"

  if [ "$mode" = "whitelist" ]; then
    current_list="$(read_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "")"
    new_list="$(list_add "$current_list" "$package")"
    set_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "$(quote_conf "$new_list")"
  else
    current_list="$(read_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "")"
    new_list="$(list_add "$current_list" "$package")"
    set_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "$(quote_conf "$new_list")"
  fi

  info "Added application: $package"
  reload_tproxy_if_running
}

cmd_app_remove() {
  local package="${1:-}"
  local proxy_list bypass_list

  [ -n "$package" ] || die_cli "Usage: cli app remove <Package name>"

  proxy_list="$(list_remove "$(read_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "")" "$package")"
  bypass_list="$(list_remove "$(read_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "")" "$package")"
  set_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "$(quote_conf "$proxy_list")"
  set_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "$(quote_conf "$bypass_list")"

  info "Removed application: $package"
  reload_tproxy_if_running
}

cmd_app_enable() {
  set_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "1"
  info "SubApplication agent enabled"
  reload_tproxy_if_running
}

cmd_app_disable() {
  set_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "0"
  info "Sub-Application Agent Disabled"
  reload_tproxy_if_running
}

cmd_app() {
  local subcmd="${1:-list}"
  shift 2> /dev/null || true

  case "$subcmd" in
    list) cmd_app_list "$@" ;;
    mode) cmd_app_mode "$@" ;;
    add) cmd_app_add "$@" ;;
    remove | rm) cmd_app_remove "$@" ;;
    enable) cmd_app_enable "$@" ;;
    disable) cmd_app_disable "$@" ;;
    help | -h | --help) show_app_help ;;
    *) die_cli "Use error, use cli app help View Help" ;;
  esac
}

#######################################
# tproxy Command
#######################################
cmd_tproxy_status() {
  section "Transparent proxy configuration"
  printf "TCP Port: %s\n" "$(read_conf "$TPROXY_CONF" "PROXY_TCP_PORT" "-")"
  printf "UDP Port: %s\n" "$(read_conf "$TPROXY_CONF" "PROXY_UDP_PORT" "-")"
  printf "DNS Port: %s\n" "$(read_conf "$TPROXY_CONF" "DNS_PORT" "-")"
  printf "Proxy Mode: %s\n" "$(read_conf "$TPROXY_CONF" "PROXY_MODE" "0")"
  printf "SubApplication Agent: %s\n" "$(read_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "0")"
  printf "Block QUIC: %s\n" "$(read_conf "$TPROXY_CONF" "BLOCK_QUIC" "0")"
  printf "Around China. IP: %s\n" "$(read_conf "$TPROXY_CONF" "BYPASS_CN_IP" "0")"
}

cmd_tproxy_reload() {
  reload_tproxy_if_running
}

cmd_tproxy_quic() {
  local value="${1:-}"

  case "$value" in
    on) set_conf "$TPROXY_CONF" "BLOCK_QUIC" "1" ;;
    off) set_conf "$TPROXY_CONF" "BLOCK_QUIC" "0" ;;
    *) die_cli "Usage: cli tproxy quic <on|off>" ;;
  esac

  info "QUIC Settings updated: $value"
  reload_tproxy_if_running
}

cmd_tproxy_cnip() {
  local value="${1:-}"

  case "$value" in
    on) set_conf "$TPROXY_CONF" "BYPASS_CN_IP" "1" ;;
    off) set_conf "$TPROXY_CONF" "BYPASS_CN_IP" "0" ;;
    *) die_cli "Usage: cli tproxy cnip <on|off>" ;;
  esac

  info "China IP _Other Organiser: $value"
  reload_tproxy_if_running
}

cmd_tproxy() {
  local subcmd="${1:-status}"
  shift 2> /dev/null || true

  case "$subcmd" in
    status) cmd_tproxy_status "$@" ;;
    reload | restart) cmd_tproxy_reload "$@" ;;
    quic) cmd_tproxy_quic "$@" ;;
    cnip) cmd_tproxy_cnip "$@" ;;
    help | -h | --help) show_tproxy_help ;;
    *) die_cli "Use error, use cli tproxy help View Help" ;;
  esac
}

#######################################
# Total help
#######################################
show_help() {
  cat << EOF
NetProxy CLI

Services:
  cli service status                  View Service Status
  cli service start                   Start-up services
  cli service stop                    Stop Service
  cli service restart                 Restart Service
  cli service logs [service|core|sub] [Lines]
                                      View Log

Nodes:
  cli node list                       List all nodes
  cli node current                    View the current node
  cli node use <Name|Label|Path>       Toggle Node
  cli node add <Node Link>             Add a single node
  cli node import <Documentation>              Import node file or Clash YAML
  cli node export <Node file>          Will sing-box Node to Link
  cli node show <Name|Label|Path>      View Node Configuration
  cli node remove <Name|Label|Path>    Delete Node
  cli node delay [Name|Label|all]      Test node delay

Mode:
  cli mode                            View Current Mode
  cli mode <rule|global|direct>       Toggle outbound mode

Subscriptions:
  cli sub list                        List Subscriptions
  cli sub add <Name> <Link>           Add Subscription
  cli sub update <Name>               Update specified subscriptions
  cli sub update-all                  Update All Subscriptions
  cli sub remove <Name>               Delete Subscriptions

Control interface:
  cli api groups                      View Agent Group
  cli api conns                       View Connections
  cli api close <ConnectionID>              Close the specified connection
  cli api close-all                   Close All Connections
  cli api ui                          View controller and panel address

SubApplication Agent:
  cli app list                        View split application proxy configuration
  cli app mode <blacklist|whitelist>  Set SubApplication Mode
  cli app add <Package name>                  Add Application
  cli app remove <Package name>               Remove Application
  cli app enable                      Enable sub-application agent
  cli app disable                     Disable branch application agent

Transparent Agent:
  cli tproxy status                   View transparent proxy configuration
  cli tproxy reload                   Loading Transparency Proxy Rules
  cli tproxy quic <on|off>            Switch QUIC Block
  cli tproxy cnip <on|off>            Switch China IP Go around.
EOF
}

#######################################
# Main entrance
#######################################
main() {
  local group="${1:-help}"
  shift 2> /dev/null || true

  ensure_cli_dirs

  case "$group" in
    service) cmd_service "$@" ;;
    node) cmd_node "$@" ;;
    mode) cmd_mode "$@" ;;
    sub) cmd_sub "$@" ;;
    api) cmd_api "$@" ;;
    app) cmd_app "$@" ;;
    tproxy) cmd_tproxy "$@" ;;
    help | -h | --help) show_help ;;
    *) die_cli "Unknown Command Group: $group, use cli help View Help" ;;
  esac
}

main "$@"
