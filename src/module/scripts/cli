#!/system/bin/sh
# NetProxy Command line tools
# usage: cli <Order> [parameter]
#
# Serve:
#   cli status                         Check service status
#   cli start                          Start service
#   cli stop                           Stop service
#   cli restart                        Restart service
#   cli logs [service|core|sub] [number of lines] View log
#
# node:
#   cli nodes                          List all nodes
#   cli current                        View current node
#   cli use <name|Label|path>            Switch node
#   cli add <node link>                 Add a single node
#   cli import <document>                  Import node file or Clash YAML
#   cli rm <name|Label|path>             Delete node
#   cli show <name|Label|path>           View node configuration
#   cli delay [name|Label|all]           Test node latency
#   cli convert <document>                 sing-box node to link
#
# model:
#   cli mode                           View outbound mode
#   cli mode <rule|global|direct>      Switch rules/overall situation/direct connection mode
#
# subscription:
#   cli sub list                       List subscriptions
#   cli sub add <name> <Link>           Add subscription
#   cli sub update <name>              Update specified subscription
#   cli sub update-all                 Update all subscriptions
#   cli sub rm <name>                  Delete subscription
#   cli sub parse <node link>           Single link transfer sing-box node
#   cli sub convert <document>             sing-box node to link
#   cli sub file <document>                file node or Clash YAML transfer node
#   cli sub sub <Link> [Table of contents]          Subscription link to node file
#
# control interface:
#   cli groups                         View agent groups and current selections
#   cli conns                          View connections
#   cli close <connectID>                 Close specified connection
#   cli close-all                      Close all connections
#   cli ui                             View panel address and key
#
# transparent proxy:
#   cli app list                       View proxy configuration by application
#   cli app mode <blacklist|whitelist> Set application mode
#   cli app add <package name>                 Add application to current mode list
#   cli app rm <package name>                  Remove app
#   cli app enable | disable           Enable or disable per-application proxy
#   cli tproxy status                  View transparent proxy configuration
#   cli tproxy reload                  Overload transparent proxy rules
#   cli tproxy quic <on|off>           switch QUIC block
#   cli tproxy cnip <on|off>           Switch China IP bypass

set -e
set -u

readonly MODDIR="$(cd "$(dirname "$0")/.." && pwd)"
readonly SCRIPTS_DIR="$MODDIR/scripts"
readonly CONFIG_DIR="$MODDIR/config"
readonly MODULE_CONF="$CONFIG_DIR/module.conf"
readonly TPROXY_DIR="$CONFIG_DIR/tproxy"
readonly TPROXY_CONF="$TPROXY_DIR/tproxy.conf"
readonly SINGBOX_DIR="$CONFIG_DIR/singbox"
readonly SINGBOX_OUTBOUNDS_DIR="$SINGBOX_DIR/outbounds"
readonly DEFAULT_NODES_DIR="$SINGBOX_OUTBOUNDS_DIR/default"
readonly RUNTIME_DIR="$SINGBOX_DIR/runtime"
readonly LOG_DIR="$MODDIR/logs"
readonly SERVICE_LOG="$LOG_DIR/service.log"
readonly CORE_LOG="$LOG_DIR/sing-box.log"
readonly SUB_LOG="$LOG_DIR/subscription.log"

readonly SING_BOX_BIN="$MODDIR/bin/sing-box"
readonly PROXYLINK_BIN="$MODDIR/bin/proxylink"
readonly SERVICE_SCRIPT="$SCRIPTS_DIR/core/service.sh"
readonly SWITCH_SCRIPT="$SCRIPTS_DIR/core/switch.sh"
readonly SUB_SCRIPT="$SCRIPTS_DIR/core/subscription.sh"
readonly TPROXY_SCRIPT="$SCRIPTS_DIR/network/tproxy.sh"

readonly CLASH_API="127.0.0.1:9999"
readonly CLASH_SECRET="singbox"
readonly SELECTOR_GROUP="Proxy"
readonly DELAY_URL="https://www.gstatic.com/generate_204"

if [ -t 1 ]; then
  readonly RED="$(printf '\033[0;31m')"
  readonly GREEN="$(printf '\033[0;32m')"
  readonly YELLOW="$(printf '\033[1;33m')"
  readonly BLUE="$(printf '\033[0;34m')"
  readonly NC="$(printf '\033[0m')"
else
  readonly RED=""
  readonly GREEN=""
  readonly YELLOW=""
  readonly BLUE=""
  readonly NC=""
fi

#######################################
# Output tools
#######################################
info() {
  printf "%s[info]%s %s\n" "$GREEN" "$NC" "$1"
}

warn() {
  printf "%s[warn]%s %s\n" "$YELLOW" "$NC" "$1"
}

die() {
  printf "%s[err]%s %s\n" "$RED" "$NC" "$1" >&2
  exit 1
}

section() {
  printf "\n%s%s%s\n" "$BLUE" "$1" "$NC"
}

#######################################
# Configure read and write
#######################################
strip_quotes() {
  printf "%s" "${1:-}" | tr -d '"' | tr -d '\r'
}

read_conf() {
  local file="$1"
  local key="$2"
  local default="${3:-}"
  local line value

  if [ -f "$file" ]; then
    line="$(grep -m 1 "^${key}=" "$file" 2> /dev/null || true)"
    if [ -n "$line" ]; then
      value="${line#*=}"
      strip_quotes "$value"
      return 0
    fi
  fi

  printf "%s" "$default"
}

set_conf() {
  local file="$1"
  local key="$2"
  local value="$3"

  [ -f "$file" ] || die "Configuration file does not exist: $file"

  if grep -q "^${key}=" "$file" 2> /dev/null; then
    sed -i "s|^${key}=.*|${key}=${value}|" "$file"
  else
    printf "%s=%s\n" "$key" "$value" >> "$file"
  fi
}

quote_conf() {
  printf '"%s"' "$1"
}

list_contains() {
  local list="$1"
  local item="$2"
  local value

  for value in $list; do
    [ "$value" = "$item" ] && return 0
  done
  return 1
}

list_add() {
  local list="$1"
  local item="$2"

  if list_contains "$list" "$item"; then
    printf "%s" "$list"
  elif [ -n "$list" ]; then
    printf "%s %s" "$list" "$item"
  else
    printf "%s" "$item"
  fi
}

list_remove() {
  local list="$1"
  local item="$2"
  local value output=""

  for value in $list; do
    [ "$value" = "$item" ] && continue
    if [ -n "$output" ]; then
      output="$output $value"
    else
      output="$value"
    fi
  done

  printf "%s" "$output"
}

#######################################
# Running status
#######################################
get_pid() {
  pidof -s "$SING_BOX_BIN" 2> /dev/null || pgrep -f "$SING_BOX_BIN" 2> /dev/null | head -1 || true
}

is_running() {
  [ -n "$(get_pid)" ]
}

ensure_dirs() {
  mkdir -p "$LOG_DIR" "$DEFAULT_NODES_DIR" "$RUNTIME_DIR"
}

#######################################
# JSON Auxiliary
#######################################
json_get_string() {
  local key="$1"
  tr ',{}' '\n' | grep -m 1 "\"$key\"" | sed 's/.*"'"$key"'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/'
}

detect_outbound_tag() {
  local file="$1"
  [ -f "$file" ] || return 1
  grep -m 1 -E '"tag"[[:space:]]*:' "$file" 2> /dev/null \
    | sed 's/.*"tag"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/'
}

url_encode_simple() {
  printf "%s" "$1" \
    | sed 's/%/%25/g; s/ /%20/g; s/#/%23/g; s/?/%3F/g; s/&/%26/g; s/\//%2F/g; s/+/%2B/g'
}

api_request() {
  local method="$1"
  local path="$2"
  local data="${3:-}"

  command -v curl > /dev/null 2>&1 || return 1

  if [ -n "$data" ]; then
    curl -fsS -X "$method" \
      -H "Authorization: Bearer $CLASH_SECRET" \
      -H "Content-Type: application/json" \
      -d "$data" \
      "http://$CLASH_API$path"
  else
    curl -fsS -X "$method" \
      -H "Authorization: Bearer $CLASH_SECRET" \
      "http://$CLASH_API$path"
  fi
}

api_mode() {
  api_request GET "/configs" 2> /dev/null | json_get_string "mode" || true
}

#######################################
# Node parsing
#######################################
node_matches_file() {
  local file="$1"
  local query="$2"
  local name base tag

  name="$(basename "$file")"
  base="${name%.json}"
  tag="$(detect_outbound_tag "$file" || true)"

  [ "$query" = "$file" ] && return 0
  [ "$query" = "$name" ] && return 0
  [ "$query" = "$base" ] && return 0
  [ -n "$tag" ] && [ "$query" = "$tag" ] && return 0

  return 1
}

resolve_node() {
  local query="$1"
  local tmp count first file

  [ -n "$query" ] || die "Please specify node name、label or path"

  if [ -f "$query" ]; then
    printf "%s\n" "$query"
    return 0
  fi

  tmp="$RUNTIME_DIR/cli_matches.$$"
  : > "$tmp"

  for file in "$DEFAULT_NODES_DIR"/*.json; do
    [ -f "$file" ] || continue
    node_matches_file "$file" "$query" && printf "%s\n" "$file" >> "$tmp"
  done

  for file in "$SINGBOX_OUTBOUNDS_DIR"/sub_*/*.json; do
    [ -f "$file" ] || continue
    [ "$(basename "$file")" = "_meta.json" ] && continue
    node_matches_file "$file" "$query" && printf "%s\n" "$file" >> "$tmp"
  done

  count="$(wc -l < "$tmp" | tr -d ' ')"
  first="$(head -1 "$tmp" 2> /dev/null || true)"
  rm -f "$tmp"

  case "$count" in
    0)
      die "Node not found: $query"
      ;;
    1)
      printf "%s\n" "$first"
      ;;
    *)
      die "Find multiple nodes with the same name，Please use a more precise filename or full path"
      ;;
  esac
}

for_each_node() {
  local file

  for file in "$DEFAULT_NODES_DIR"/*.json; do
    [ -f "$file" ] || continue
    printf "%s\n" "$file"
  done

  for file in "$SINGBOX_OUTBOUNDS_DIR"/sub_*/*.json; do
    [ -f "$file" ] || continue
    [ "$(basename "$file")" = "_meta.json" ] && continue
    printf "%s\n" "$file"
  done
}

#######################################
# Service control
#######################################
cmd_status() {
  local pid current mode version api current_name tcp_port udp_port dns_port

  section "NetProxy state"

  pid="$(get_pid)"
  if [ -n "$pid" ]; then
    printf "Service status: %sRunning%s\n" "$GREEN" "$NC"
    echo "process PID: $pid"
  else
    printf "Service status: %sStopped%s\n" "$RED" "$NC"
  fi

  current="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"
  current_name="$(basename "$current" 2> /dev/null || true)"
  [ -n "$current_name" ] && echo "current node: $current_name"

  mode="$(read_conf "$MODULE_CONF" "OUTBOUND_MODE" "rule")"
  echo "outbound mode: $mode"

  if [ -n "$pid" ]; then
    api="$(api_mode)"
    [ -n "$api" ] && echo "control interface mode: $api"
  fi

  tcp_port="$(read_conf "$TPROXY_CONF" "PROXY_TCP_PORT" "-")"
  udp_port="$(read_conf "$TPROXY_CONF" "PROXY_UDP_PORT" "-")"
  dns_port="$(read_conf "$TPROXY_CONF" "DNS_PORT" "-")"
  echo "Transparent proxy port: TCP=$tcp_port UDP=$udp_port DNS=$dns_port"

  if [ -x "$SING_BOX_BIN" ]; then
    version="$("$SING_BOX_BIN" version 2> /dev/null | head -1 || true)"
    [ -n "$version" ] && echo "Kernel version: $version"
  fi
}

cmd_start() {
  is_running && { warn "Service is already running"; return 0; }
  ensure_dirs
  info "Starting service..."
  sh "$SERVICE_SCRIPT" start
}

cmd_stop() {
  is_running || { warn "Service is not running"; return 0; }
  info "Stopping service..."
  sh "$SERVICE_SCRIPT" stop
}

cmd_restart() {
  ensure_dirs
  info "Restarting service..."
  sh "$SERVICE_SCRIPT" restart
}

cmd_logs() {
  local target="${1:-service}"
  local lines="${2:-80}"
  local file

  case "$target" in
    service) file="$SERVICE_LOG" ;;
    core | sing-box | singbox) file="$CORE_LOG" ;;
    sub | subscription) file="$SUB_LOG" ;;
    *) die "Unknown log type: $target" ;;
  esac

  [ -f "$file" ] || die "Log file does not exist: $file"
  tail -n "$lines" "$file"
}

#######################################
# Node management
#######################################
print_node_line() {
  local file="$1"
  local current="$2"
  local name tag mark

  name="$(basename "$file")"
  tag="$(detect_outbound_tag "$file" || true)"
  mark=" "
  [ "$file" = "$current" ] && mark="*"

  if [ -n "$tag" ]; then
    printf "  %s %-32s %s\n" "$mark" "$name" "$tag"
  else
    printf "  %s %s\n" "$mark" "$name"
  fi
}

cmd_nodes() {
  local current file sub_dir meta name count

  current="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"

  section "default node"
  count=0
  for file in "$DEFAULT_NODES_DIR"/*.json; do
    [ -f "$file" ] || continue
    print_node_line "$file" "$current"
    count=$((count + 1))
  done
  [ "$count" -eq 0 ] && echo "  No node yet"

  for sub_dir in "$SINGBOX_OUTBOUNDS_DIR"/sub_*; do
    [ -d "$sub_dir" ] || continue
    meta="$sub_dir/_meta.json"
    name="$(basename "$sub_dir")"
    [ -f "$meta" ] && name="$(grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' "$meta" | sed 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')"
    section "subscription: $name"
    count=0
    for file in "$sub_dir"/*.json; do
      [ -f "$file" ] || continue
      [ "$(basename "$file")" = "_meta.json" ] && continue
      print_node_line "$file" "$current"
      count=$((count + 1))
    done
    [ "$count" -eq 0 ] && echo "  No node yet"
  done
}

cmd_current() {
  local current mode tag

  current="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"
  mode="$(read_conf "$MODULE_CONF" "OUTBOUND_MODE" "rule")"

  section "Current configuration"
  echo "outbound mode: $mode"
  if [ -n "$current" ]; then
    tag="$(detect_outbound_tag "$current" || true)"
    echo "node file: $(basename "$current")"
    [ -n "$tag" ] && echo "node label: $tag"
    echo "full path: $current"
  else
    echo "Current node is not set"
  fi
}

cmd_use() {
  local query="${1:-}"
  local node

  node="$(resolve_node "$query")"
  info "Switch node: $(basename "$node")"
  sh "$SWITCH_SCRIPT" config "$node"
}

cmd_add() {
  local link="${1:-}"

  [ -n "$link" ] || die "usage: cli add <node link>"
  [ -x "$PROXYLINK_BIN" ] || die "proxylink Does not exist or is not enforceable: $PROXYLINK_BIN"

  info "Importing nodes..."
  sh "$SUB_SCRIPT" parse "$link" "$DEFAULT_NODES_DIR"
  info "Node import completed"
}

cmd_import() {
  local file="${1:-}"

  [ -n "$file" ] || die "usage: cli import <document>"
  [ -f "$file" ] || die "File does not exist: $file"
  [ -x "$PROXYLINK_BIN" ] || die "proxylink Does not exist or is not enforceable: $PROXYLINK_BIN"

  info "Importing files..."
  sh "$SUB_SCRIPT" file "$file" "$DEFAULT_NODES_DIR"
  info "File import completed"
}

cmd_rm() {
  local query="${1:-}"
  local node current

  node="$(resolve_node "$query")"
  current="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"

  [ "$node" = "$current" ] && die "Cannot delete node currently in use"
  rm -f "$node"
  info "Node deleted: $(basename "$node")"
}

cmd_show() {
  local query="${1:-}"
  local node

  node="$(resolve_node "$query")"
  echo "document: $node"
  echo "--------------------------------"
  cat "$node"
}

cmd_convert() {
  local file="${1:-}"
  [ -n "$file" ] || die "usage: cli convert <document>"
  sh "$SUB_SCRIPT" convert "$file"
}

#######################################
# Outbound mode and control interface
#######################################
cmd_mode() {
  local mode="${1:-}"
  local current api

  if [ -z "$mode" ]; then
    current="$(read_conf "$MODULE_CONF" "OUTBOUND_MODE" "rule")"
    echo "persistence mode: $current"
    if is_running; then
      api="$(api_mode)"
      [ -n "$api" ] && echo "operating mode: $api"
    fi
    return 0
  fi

  case "$mode" in
    rule | global | direct) ;;
    *) die "Unknown mode: $mode，Optional: rule/global/direct" ;;
  esac

  sh "$SWITCH_SCRIPT" mode "$mode"
}

cmd_groups() {
  local json compact block now all item

  json="$(api_request GET "/proxies" 2> /dev/null)" || die "Control interface is unavailable，Please confirm the service is running"
  compact="$(printf "%s" "$json" | tr -d '\n' | tr -d ' ')"
  block="$(printf "%s" "$compact" | sed 's/.*"'"$SELECTOR_GROUP"'":{\([^}]*\)}.*/\1/')"

  section "agent group"
  if [ "$block" != "$compact" ]; then
    now="$(printf "%s" "$block" | sed 's/.*"now":"\([^"]*\)".*/\1/')"
    all="$(printf "%s" "$block" | sed 's/.*"all":\[\([^]]*\)\].*/\1/' | tr -d '"' | tr ',' ' ')"
    [ -n "$now" ] && echo "$SELECTOR_GROUP: $now"
    if [ -n "$all" ]; then
      echo "optional node:"
      for item in $all; do
        echo "  - $item"
      done
    fi
  else
    echo "$json"
  fi
}

delay_one() {
  local tag="$1"
  local encoded result delay

  encoded="$(url_encode_simple "$tag")"
  result="$(api_request GET "/proxies/$encoded/delay?timeout=5000&url=$DELAY_URL" 2> /dev/null || true)"
  delay="$(printf "%s" "$result" | sed 's/.*"delay"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/')"

  if [ -n "$delay" ] && [ "$delay" != "$result" ]; then
    printf "%-32s %sms\n" "$tag" "$delay"
  else
    printf "%-32s %s\n" "$tag" "fail"
  fi
}

cmd_delay() {
  local query="${1:-}"
  local node tag current

  if [ "$query" = "all" ]; then
    for node in $(for_each_node); do
      tag="$(detect_outbound_tag "$node" || true)"
      [ -n "$tag" ] && delay_one "$tag"
    done
    return 0
  fi

  if [ -n "$query" ]; then
    if node="$(resolve_node "$query" 2> /dev/null)"; then
      tag="$(detect_outbound_tag "$node" || true)"
    else
      tag="$query"
    fi
  else
    current="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"
    [ -n "$current" ] || die "The current node is not set"
    tag="$(detect_outbound_tag "$current" || true)"
  fi

  [ -n "$tag" ] || die "Unable to read node label"
  delay_one "$tag"
}

cmd_conns() {
  local json total ids id count

  json="$(api_request GET "/connections" 2> /dev/null)" || die "Control interface is unavailable，Please confirm the service is running"
  total="$(printf "%s" "$json" | sed 's/.*"downloadTotal"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/')"
  [ -n "$total" ] && [ "$total" != "$json" ] && echo "Total downloads: $total bytes"

  ids="$(printf "%s" "$json" | grep -o '"id"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' || true)"
  if [ -n "$ids" ]; then
    echo "connection list:"
    count=0
    for id in $ids; do
      echo "  - $id"
      count=$((count + 1))
      [ "$count" -ge 20 ] && break
    done
  else
    echo "$json"
  fi
}

cmd_close() {
  local id="${1:-}"
  local encoded

  [ -n "$id" ] || die "usage: cli close <connectID>"
  encoded="$(url_encode_simple "$id")"
  api_request DELETE "/connections/$encoded" > /dev/null 2>&1 || die "Failed to close connection"
  info "connection closed: $id"
}

cmd_close_all() {
  api_request DELETE "/connections" > /dev/null 2>&1 || die "Failed to close connection"
  info "All connections closed"
}

cmd_ui() {
  local ip

  ip="$(ip route get 1.1.1.1 2> /dev/null | sed -n 's/.* src \([0-9.]*\).*/\1/p' | head -1)"
  [ -n "$ip" ] || ip="<equipmentIP>"

  echo "control address: http://$ip:9999"
  echo "Panel address: http://$ip:9999/ui"
  echo "key: $CLASH_SECRET"
}

#######################################
# Subscription management
#######################################
cmd_sub() {
  local subcmd="${1:-}"
  shift 2> /dev/null || true

  case "$subcmd" in
    list) sh "$SUB_SCRIPT" list ;;
    add) sh "$SUB_SCRIPT" add "${1:-}" "${2:-}" ;;
    update) sh "$SUB_SCRIPT" update "${1:-}" ;;
    update-all) sh "$SUB_SCRIPT" update-all ;;
    rm | remove) sh "$SUB_SCRIPT" remove "${1:-}" ;;
    parse) sh "$SUB_SCRIPT" parse "${1:-}" "${2:-}" ;;
    convert) sh "$SUB_SCRIPT" convert "${1:-}" ;;
    file | import) sh "$SUB_SCRIPT" file "${1:-}" "${2:-}" ;;
    sub | fetch) sh "$SUB_SCRIPT" sub "${1:-}" "${2:-}" ;;
    *) die "usage: cli sub {list|add|update|update-all|rm|parse|convert|file|sub}" ;;
  esac
}

#######################################
# Transparent proxy configuration
#######################################
reload_tproxy_if_running() {
  if is_running; then
    info "Reloading transparent proxy rules..."
    sh "$TPROXY_SCRIPT" restart -d "$TPROXY_DIR" > /dev/null 2>&1 || die "Transparent proxy rule reload failed"
    info "Transparent proxy rules have been overloaded"
  else
    info "Service is not running，The configuration will take effect on the next startup"
  fi
}

cmd_app() {
  local subcmd="${1:-}"
  local mode enable proxy_list bypass_list package new_list
  shift 2> /dev/null || true

  case "$subcmd" in
    list)
      mode="$(read_conf "$TPROXY_CONF" "APP_PROXY_MODE" "blacklist")"
      enable="$(read_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "0")"
      proxy_list="$(read_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "")"
      bypass_list="$(read_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "")"
      echo "Application agent: $enable"
      echo "application mode: $mode"
      echo "proxy list: ${proxy_list:-null}"
      echo "bypass list: ${bypass_list:-null}"
      ;;
    mode)
      mode="${1:-}"
      case "$mode" in
        blacklist | whitelist) ;;
        *) die "usage: cli app mode <blacklist|whitelist>" ;;
      esac
      set_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "1"
      set_conf "$TPROXY_CONF" "APP_PROXY_MODE" "$(quote_conf "$mode")"
      info "Application mode is set to: $mode"
      reload_tproxy_if_running
      ;;
    add)
      package="${1:-}"
      [ -n "$package" ] || die "usage: cli app add <package name>"
      set_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "1"
      mode="$(read_conf "$TPROXY_CONF" "APP_PROXY_MODE" "blacklist")"
      if [ "$mode" = "whitelist" ]; then
        proxy_list="$(read_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "")"
        new_list="$(list_add "$proxy_list" "$package")"
        set_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "$(quote_conf "$new_list")"
      else
        bypass_list="$(read_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "")"
        new_list="$(list_add "$bypass_list" "$package")"
        set_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "$(quote_conf "$new_list")"
      fi
      info "App added: $package"
      reload_tproxy_if_running
      ;;
    rm | remove)
      package="${1:-}"
      [ -n "$package" ] || die "usage: cli app rm <package name>"
      proxy_list="$(list_remove "$(read_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "")" "$package")"
      bypass_list="$(list_remove "$(read_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "")" "$package")"
      set_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "$(quote_conf "$proxy_list")"
      set_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "$(quote_conf "$bypass_list")"
      info "App removed: $package"
      reload_tproxy_if_running
      ;;
    enable)
      set_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "1"
      info "Sub-application proxy is enabled"
      reload_tproxy_if_running
      ;;
    disable)
      set_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "0"
      info "Sub-application proxy is disabled"
      reload_tproxy_if_running
      ;;
    *) die "usage: cli app {list|mode|add|rm|enable|disable}" ;;
  esac
}

cmd_tproxy() {
  local subcmd="${1:-}"
  local value="${2:-}"

  case "$subcmd" in
    status)
      section "Transparent proxy configuration"
      echo "TCP port: $(read_conf "$TPROXY_CONF" "PROXY_TCP_PORT" "-")"
      echo "UDP port: $(read_conf "$TPROXY_CONF" "PROXY_UDP_PORT" "-")"
      echo "DNS port: $(read_conf "$TPROXY_CONF" "DNS_PORT" "-")"
      echo "proxy mode: $(read_conf "$TPROXY_CONF" "PROXY_MODE" "0")"
      echo "Application agent: $(read_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "0")"
      echo "block QUIC: $(read_conf "$TPROXY_CONF" "BLOCK_QUIC" "0")"
      echo "Bypass China IP: $(read_conf "$TPROXY_CONF" "BYPASS_CN_IP" "0")"
      ;;
    reload | restart)
      reload_tproxy_if_running
      ;;
    quic)
      case "$value" in
        on) set_conf "$TPROXY_CONF" "BLOCK_QUIC" "1" ;;
        off) set_conf "$TPROXY_CONF" "BLOCK_QUIC" "0" ;;
        *) die "usage: cli tproxy quic <on|off>" ;;
      esac
      info "QUIC Settings updated: $value"
      reload_tproxy_if_running
      ;;
    cnip)
      case "$value" in
        on) set_conf "$TPROXY_CONF" "BYPASS_CN_IP" "1" ;;
        off) set_conf "$TPROXY_CONF" "BYPASS_CN_IP" "0" ;;
        *) die "usage: cli tproxy cnip <on|off>" ;;
      esac
      info "China IP bypass updated: $value"
      reload_tproxy_if_running
      ;;
    *) die "usage: cli tproxy {status|reload|quic|cnip}" ;;
  esac
}

#######################################
# help
#######################################
show_help() {
  cat << EOF
NetProxy CLI

Serve:
  cli status
  cli start | stop | restart
  cli logs [service|core|sub] [number of lines]

node:
  cli nodes
  cli current
  cli use <name|Label|path>
  cli add <node link>
  cli import <document>
  cli rm <name|Label|path>
  cli show <name|Label|path>
  cli convert <document>
  cli delay [name|Label|all]

model:
  cli mode
  cli mode <rule|global|direct>

subscription:
  cli sub list
  cli sub add <name> <Link>
  cli sub update <name>
  cli sub update-all
  cli sub rm <name>
  cli sub parse <node link>
  cli sub convert <document>
  cli sub file <document>
  cli sub sub <Link> [Table of contents]

control interface:
  cli groups
  cli conns
  cli close <connectID>
  cli close-all
  cli ui

transparent proxy:
  cli app list
  cli app mode <blacklist|whitelist>
  cli app add <package name>
  cli app rm <package name>
  cli app enable | disable
  cli tproxy status
  cli tproxy reload
  cli tproxy quic <on|off>
  cli tproxy cnip <on|off>
EOF
}

#######################################
# main entrance
#######################################
main() {
  local cmd="${1:-help}"
  shift 2> /dev/null || true

  ensure_dirs

  case "$cmd" in
    status) cmd_status "$@" ;;
    start) cmd_start "$@" ;;
    stop) cmd_stop "$@" ;;
    restart) cmd_restart "$@" ;;
    logs) cmd_logs "$@" ;;
    nodes | ls) cmd_nodes "$@" ;;
    current) cmd_current "$@" ;;
    use) cmd_use "$@" ;;
    add) cmd_add "$@" ;;
    import) cmd_import "$@" ;;
    rm | remove) cmd_rm "$@" ;;
    show) cmd_show "$@" ;;
    convert) cmd_convert "$@" ;;
    delay) cmd_delay "$@" ;;
    mode) cmd_mode "$@" ;;
    sub | subscription) cmd_sub "$@" ;;
    groups) cmd_groups "$@" ;;
    conns | connections) cmd_conns "$@" ;;
    close) cmd_close "$@" ;;
    close-all) cmd_close_all "$@" ;;
    app) cmd_app "$@" ;;
    tproxy) cmd_tproxy "$@" ;;
    ui) cmd_ui "$@" ;;
    help | -h | --help) show_help ;;
    *) die "unknown command: $cmd，use cli help View help" ;;
  esac
}

main "$@"
