#!/system/bin/sh
# NetProxy 命令行工具

set -e
set -u

readonly MODDIR="$(cd "$(dirname "$0")/.." && pwd)"
readonly SCRIPTS_DIR="$MODDIR/scripts"
readonly CONFIG_DIR="$MODDIR/config"
readonly MODULE_CONF="$CONFIG_DIR/module.conf"
readonly TPROXY_DIR="$CONFIG_DIR/tproxy"
readonly TPROXY_CONF="$TPROXY_DIR/tproxy.conf"
readonly SINGBOX_DIR="$CONFIG_DIR/singbox"
readonly SINGBOX_OUTBOUNDS_DIR="$SINGBOX_DIR/outbounds"
readonly DEFAULT_NODES_DIR="$SINGBOX_OUTBOUNDS_DIR/default"
readonly RUNTIME_DIR="$SINGBOX_DIR/runtime"
readonly CLI_NODE_SCAN_FILE="$RUNTIME_DIR/cli_nodes.tsv"
readonly LOG_DIR="$MODDIR/logs"
readonly SERVICE_LOG="$LOG_DIR/service.log"
readonly CORE_LOG="$LOG_DIR/sing-box.log"
readonly SUB_LOG="$LOG_DIR/subscription.log"

readonly SING_BOX_BIN="$MODDIR/bin/sing-box"
readonly PROXYLINK_BIN="$MODDIR/bin/proxylink"
readonly SERVICE_SCRIPT="$SCRIPTS_DIR/core/service.sh"
readonly SWITCH_SCRIPT="$SCRIPTS_DIR/core/switch.sh"
readonly SUB_SCRIPT="$SCRIPTS_DIR/core/subscription.sh"
readonly TPROXY_SCRIPT="$SCRIPTS_DIR/network/tproxy.sh"

readonly CLASH_API="127.0.0.1:9999"
readonly CLASH_SECRET="singbox"
readonly SELECTOR_GROUP="Proxy"
readonly DELAY_URL="https://www.gstatic.com/generate_204"

. "$MODDIR/scripts/utils/common.sh"
. "$MODDIR/scripts/utils/config.sh"
. "$MODDIR/scripts/utils/api.sh"
. "$MODDIR/scripts/utils/nodes.sh"

if [ -t 1 ]; then
  readonly RED="$(printf '\033[0;31m')"
  readonly GREEN="$(printf '\033[0;32m')"
  readonly YELLOW="$(printf '\033[1;33m')"
  readonly BLUE="$(printf '\033[0;34m')"
  readonly NC="$(printf '\033[0m')"
else
  readonly RED=""
  readonly GREEN=""
  readonly YELLOW=""
  readonly BLUE=""
  readonly NC=""
fi

#######################################
# 终端输出
#######################################
info() {
  printf "%s[info]%s %s\n" "$GREEN" "$NC" "$1"
}

warn() {
  printf "%s[warn]%s %s\n" "$YELLOW" "$NC" "$1"
}

die_cli() {
  printf "%s[错误]%s %s\n" "$RED" "$NC" "$1" >&2
  exit 1
}

section() {
  printf "\n%s%s%s\n" "$BLUE" "$1" "$NC"
}

#######################################
# 基础辅助
#######################################
is_running() {
  [ -n "$(get_pid "$SING_BOX_BIN")" ]
}

ensure_cli_dirs() {
  ensure_dir "$LOG_DIR" "无法创建日志目录: $LOG_DIR"
  ensure_dir "$DEFAULT_NODES_DIR" "无法创建默认节点目录: $DEFAULT_NODES_DIR"
  ensure_dir "$RUNTIME_DIR" "无法创建运行时目录: $RUNTIME_DIR"
}

prepare_node_scan() {
  local current_config

  ensure_cli_dirs
  current_config="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"
  scan_all_nodes "$SINGBOX_OUTBOUNDS_DIR" "$current_config" "$CLI_NODE_SCAN_FILE"
}

print_node_line() {
  local path="$1"
  local name="$2"
  local tag="$3"
  local source="$4"
  local is_current="$5"
  local mark=" "

  [ "$is_current" = "1" ] && mark="*"

  if [ -n "$tag" ]; then
    printf "  %s %-24s %s\n" "$mark" "$name" "$tag"
  else
    printf "  %s %s\n" "$mark" "$name"
  fi
}

show_service_help() {
  cat << EOF
用法:
  cli service status                  查看服务状态
  cli service start                   启动服务
  cli service stop                    停止服务
  cli service restart                 重启服务
  cli service logs [service|core|sub] [行数]
                                      查看日志
EOF
}

show_node_help() {
  cat << EOF
用法:
  cli node list                       列出全部节点
  cli node current                    查看当前节点
  cli node use <名称|标签|路径>       切换节点
  cli node add <节点链接>             添加单个节点
  cli node import <文件>              导入节点文件或 Clash YAML
  cli node export <节点文件>          将 sing-box 节点转为链接
  cli node show <名称|标签|路径>      查看节点配置
  cli node remove <名称|标签|路径>    删除节点
  cli node delay [名称|标签|all]      测试节点延迟
EOF
}

show_mode_help() {
  cat << EOF
用法:
  cli mode                            查看当前模式
  cli mode <rule|global|direct>       切换出站模式
EOF
}

show_sub_help() {
  cat << EOF
用法:
  cli sub list                        列出订阅
  cli sub add <名称> <链接>           添加订阅
  cli sub update <名称>               更新指定订阅
  cli sub update-all                  更新全部订阅
  cli sub remove <名称>               删除订阅
EOF
}

show_api_help() {
  cat << EOF
用法:
  cli api groups                      查看代理组
  cli api conns                       查看连接
  cli api close <连接ID>              关闭指定连接
  cli api close-all                   关闭全部连接
  cli api ui                          查看控制器与面板地址
EOF
}

show_app_help() {
  cat << EOF
用法:
  cli app list                        查看分应用代理配置
  cli app mode <blacklist|whitelist>  设置分应用模式
  cli app add <包名>                  添加应用
  cli app remove <包名>               移除应用
  cli app enable                      启用分应用代理
  cli app disable                     禁用分应用代理
EOF
}

show_tproxy_help() {
  cat << EOF
用法:
  cli tproxy status                   查看透明代理配置
  cli tproxy reload                   重载透明代理规则
  cli tproxy quic <on|off>            开关 QUIC 阻断
  cli tproxy cnip <on|off>            开关中国 IP 绕过
EOF
}

#######################################
# service 命令
#######################################
cmd_service_status() {
  local pid current mode version api_mode tcp_port udp_port dns_port

  section "服务状态"
  pid="$(get_pid "$SING_BOX_BIN")"

  if [ -n "$pid" ]; then
    printf "运行状态: %s运行中%s\n" "$GREEN" "$NC"
    printf "进程 PID: %s\n" "$pid"
    printf "运行时间: %s 秒\n" "$(get_process_uptime "$pid")"
  else
    printf "运行状态: %s未运行%s\n" "$RED" "$NC"
  fi

  current="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"
  mode="$(read_conf "$MODULE_CONF" "OUTBOUND_MODE" "rule")"
  tcp_port="$(read_conf "$TPROXY_CONF" "PROXY_TCP_PORT" "-")"
  udp_port="$(read_conf "$TPROXY_CONF" "PROXY_UDP_PORT" "-")"
  dns_port="$(read_conf "$TPROXY_CONF" "DNS_PORT" "-")"

  [ -n "$current" ] && printf "当前节点: %s\n" "$(basename "$current")"
  printf "出站模式: %s\n" "$mode"
  printf "透明代理端口: TCP=%s UDP=%s DNS=%s\n" "$tcp_port" "$udp_port" "$dns_port"

  if [ -n "$pid" ]; then
    api_mode="$(api_get_mode 2> /dev/null || true)"
    [ -n "$api_mode" ] && printf "运行模式: %s\n" "$api_mode"
  fi

  if [ -x "$SING_BOX_BIN" ]; then
    version="$("$SING_BOX_BIN" version 2> /dev/null | head -1 || true)"
    [ -n "$version" ] && printf "内核版本: %s\n" "$version"
  fi
}

cmd_service_start() {
  ensure_cli_dirs
  info "正在启动服务..."
  sh "$SERVICE_SCRIPT" start
}

cmd_service_stop() {
  ensure_cli_dirs
  info "正在停止服务..."
  sh "$SERVICE_SCRIPT" stop
}

cmd_service_restart() {
  ensure_cli_dirs
  info "正在重启服务..."
  sh "$SERVICE_SCRIPT" restart
}

cmd_service_logs() {
  local target="${1:-service}"
  local lines="${2:-80}"
  local file

  case "$target" in
    service) file="$SERVICE_LOG" ;;
    core | sing-box | singbox) file="$CORE_LOG" ;;
    sub | subscription) file="$SUB_LOG" ;;
    *) die_cli "未知日志类型: $target" ;;
  esac

  [ -f "$file" ] || die_cli "日志文件不存在: $file"
  tail -n "$lines" "$file"
}

cmd_service() {
  local subcmd="${1:-status}"
  shift 2> /dev/null || true

  case "$subcmd" in
    status) cmd_service_status "$@" ;;
    start) cmd_service_start "$@" ;;
    stop) cmd_service_stop "$@" ;;
    restart) cmd_service_restart "$@" ;;
    logs) cmd_service_logs "$@" ;;
    help | -h | --help) show_service_help ;;
    *) die_cli "用法错误，使用 cli service help 查看帮助" ;;
  esac
}

#######################################
# node 命令
#######################################
cmd_node_list() {
  local path name tag source is_current current_source="" count=0

  prepare_node_scan

  while IFS="$NODE_RECORD_DELIM" read -r path name tag source is_current; do
    if [ "$source" != "$current_source" ]; then
      section "$source"
      current_source="$source"
    fi
    print_node_line "$path" "$name" "$tag" "$source" "$is_current"
    count=$((count + 1))
  done < "$CLI_NODE_SCAN_FILE"

  [ "$count" -gt 0 ] || printf "暂无节点\n"
}

cmd_node_current() {
  local current tag

  current="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"
  if [ -z "$current" ]; then
    printf "当前未设置节点\n"
    return 0
  fi

  tag="$(detect_outbound_tag "$current" || true)"

  section "当前节点"
  printf "文件名: %s\n" "$(basename "$current")"
  [ -n "$tag" ] && printf "标签: %s\n" "$tag"
  printf "路径: %s\n" "$current"
}

cmd_node_use() {
  local query="${1:-}"
  local node

  [ -n "$query" ] || die_cli "用法: cli node use <名称|标签|路径>"
  prepare_node_scan
  node="$(resolve_node_from_scan "$CLI_NODE_SCAN_FILE" "$query")"
  info "正在切换节点: $(basename "$node")"
  sh "$SWITCH_SCRIPT" config "$node"
}

cmd_node_add() {
  local link="${1:-}"

  [ -n "$link" ] || die_cli "用法: cli node add <节点链接>"
  info "正在导入节点..."
  sh "$SUB_SCRIPT" parse "$link" "$DEFAULT_NODES_DIR"
  info "Node import completed"
}

cmd_node_import() {
  local file="${1:-}"

  [ -n "$file" ] || die_cli "用法: cli node import <文件>"
  [ -f "$file" ] || die_cli "文件不存在: $file"
  info "正在导入文件..."
  sh "$SUB_SCRIPT" file "$file" "$DEFAULT_NODES_DIR"
  info "File import completed"
}

cmd_node_export() {
  local query="${1:-}"
  local node

  [ -n "$query" ] || die_cli "用法: cli node export <节点文件>"
  prepare_node_scan
  if [ -f "$query" ]; then
    node="$query"
  else
    node="$(resolve_node_from_scan "$CLI_NODE_SCAN_FILE" "$query")"
  fi
  sh "$SUB_SCRIPT" convert "$node"
}

cmd_node_show() {
  local query="${1:-}"
  local node

  [ -n "$query" ] || die_cli "用法: cli node show <名称|标签|路径>"
  prepare_node_scan
  node="$(resolve_node_from_scan "$CLI_NODE_SCAN_FILE" "$query")"
  printf "文件: %s\n" "$node"
  printf -- "--------------------------------\n"
  cat "$node"
}

cmd_node_remove() {
  local query="${1:-}"
  local node current

  [ -n "$query" ] || die_cli "用法: cli node remove <名称|标签|路径>"
  prepare_node_scan
  node="$(resolve_node_from_scan "$CLI_NODE_SCAN_FILE" "$query")"
  current="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"

  [ "$node" != "$current" ] || die_cli "不能删除当前正在使用的节点"
  rm -f "$node"
  info "Node deleted: $(basename "$node")"
}

delay_one() {
  local tag="$1"
  local result delay

  result="$(api_test_delay "$tag" "$(api_delay_url)" 5000 2> /dev/null || true)"
  delay="$(printf "%s" "$result" | sed -n 's/.*"delay"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p')"

  if [ -n "$delay" ]; then
    printf "%-24s %s ms\n" "$tag" "$delay"
  else
    printf "%-24s %s\n" "$tag" "失败"
  fi
}

cmd_node_delay() {
  local query="${1:-}"
  local node tag path name source is_current

  if [ "$query" = "all" ]; then
    prepare_node_scan
    while IFS="$NODE_RECORD_DELIM" read -r path name tag source is_current; do
      [ -n "$tag" ] || continue
      delay_one "$tag"
    done < "$CLI_NODE_SCAN_FILE"
    return 0
  fi

  if [ -n "$query" ]; then
    prepare_node_scan
    if node="$(resolve_node_from_scan "$CLI_NODE_SCAN_FILE" "$query" 2> /dev/null)"; then
      tag="$(detect_outbound_tag "$node" || true)"
    else
      tag="$query"
    fi
  else
    node="$(read_conf "$MODULE_CONF" "CURRENT_CONFIG" "")"
    [ -n "$node" ] || die_cli "当前未设置节点"
    tag="$(detect_outbound_tag "$node" || true)"
  fi

  [ -n "$tag" ] || die_cli "无法读取节点标签"
  delay_one "$tag"
}

cmd_node() {
  local subcmd="${1:-list}"
  shift 2> /dev/null || true

  case "$subcmd" in
    list) cmd_node_list "$@" ;;
    current) cmd_node_current "$@" ;;
    use) cmd_node_use "$@" ;;
    add) cmd_node_add "$@" ;;
    import) cmd_node_import "$@" ;;
    export) cmd_node_export "$@" ;;
    show) cmd_node_show "$@" ;;
    remove | rm) cmd_node_remove "$@" ;;
    delay) cmd_node_delay "$@" ;;
    help | -h | --help) show_node_help ;;
    *) die_cli "用法错误，使用 cli node help 查看帮助" ;;
  esac
}

#######################################
# mode 命令
#######################################
cmd_mode() {
  local mode="${1:-}"
  local current api_mode

  if [ -z "$mode" ]; then
    current="$(read_conf "$MODULE_CONF" "OUTBOUND_MODE" "rule")"
    printf "持久化模式: %s\n" "$current"
    if is_running; then
      api_mode="$(api_get_mode 2> /dev/null || true)"
      [ -n "$api_mode" ] && printf "运行模式: %s\n" "$api_mode"
    fi
    return 0
  fi

  case "$mode" in
    rule | global | direct) ;;
    help | -h | --help)
      show_mode_help
      return 0
      ;;
    *)
      die_cli "未知模式: $mode"
      ;;
  esac

  sh "$SWITCH_SCRIPT" mode "$mode"
}

#######################################
# sub 命令
#######################################
cmd_sub() {
  local subcmd="${1:-list}"
  shift 2> /dev/null || true

  case "$subcmd" in
    list) sh "$SUB_SCRIPT" list ;;
    add) sh "$SUB_SCRIPT" add "${1:-}" "${2:-}" ;;
    update) sh "$SUB_SCRIPT" update "${1:-}" ;;
    update-all) sh "$SUB_SCRIPT" update-all ;;
    remove | rm) sh "$SUB_SCRIPT" remove "${1:-}" ;;
    help | -h | --help) show_sub_help ;;
    *) die_cli "用法错误，使用 cli sub help 查看帮助" ;;
  esac
}

#######################################
# api 命令
#######################################
cmd_api_groups() {
  local json now item has_output=0

  json="$(api_get_proxies 2> /dev/null)" || die_cli "控制接口不可用，请确认服务正在运行"
  now="$(api_selector_current "$json" "$(api_selector_group)" || true)"

  section "代理组"
  [ -n "$now" ] && printf "%s: %s\n" "$(api_selector_group)" "$now"

  while IFS= read -r item; do
    [ -n "$item" ] || continue
    [ "$item" = "$now" ] && continue
    if [ "$has_output" -eq 0 ]; then
      printf "可选节点:\n"
      has_output=1
    fi
    printf "  - %s\n" "$item"
  done << EOF
$(api_selector_options "$json" "$(api_selector_group)" 2> /dev/null || true)
EOF

  [ "$has_output" -eq 1 ] || printf "暂无可选节点信息\n"
}

cmd_api_conns() {
  local json total ids id count=0

  json="$(api_get_connections 2> /dev/null)" || die_cli "控制接口不可用，请确认服务正在运行"
  total="$(printf "%s" "$json" | sed -n 's/.*"downloadTotal"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p')"
  [ -n "$total" ] && printf "下载总量: %s bytes\n" "$total"

  ids="$(printf "%s" "$json" | grep -o '"id"[[:space:]]*:[[:space:]]*"[^"]*"' | sed -n 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' || true)"
  if [ -n "$ids" ]; then
    printf "连接列表:\n"
    for id in $ids; do
      printf "  - %s\n" "$id"
      count=$((count + 1))
      [ "$count" -ge 20 ] && break
    done
  else
    printf "%s\n" "$json"
  fi
}

cmd_api_close() {
  local id="${1:-}"

  [ -n "$id" ] || die_cli "用法: cli api close <连接ID>"
  api_close_connection "$id" || die_cli "关闭连接失败"
  info "连接已关闭: $id"
}

cmd_api_close_all() {
  api_close_all_connections || die_cli "关闭全部连接失败"
  info "全部连接已关闭"
}

cmd_api_ui() {
  local ip

  ip="$(detect_primary_ipv4)"
  [ -n "$ip" ] || ip="<设备IP>"

  printf "控制地址: http://%s:9999\n" "$ip"
  printf "面板地址: http://%s:9999/ui\n" "$ip"
  printf "密钥: %s\n" "$(api_secret)"
}

cmd_api() {
  local subcmd="${1:-groups}"
  shift 2> /dev/null || true

  case "$subcmd" in
    groups) cmd_api_groups "$@" ;;
    conns) cmd_api_conns "$@" ;;
    close) cmd_api_close "$@" ;;
    close-all) cmd_api_close_all "$@" ;;
    ui) cmd_api_ui "$@" ;;
    help | -h | --help) show_api_help ;;
    *) die_cli "用法错误，使用 cli api help 查看帮助" ;;
  esac
}

#######################################
# app 命令
#######################################
reload_tproxy_if_running() {
  if is_running; then
    info "正在重载透明代理规则..."
    sh "$TPROXY_SCRIPT" restart -d "$TPROXY_DIR" > /dev/null 2>&1 || die_cli "透明代理规则重载失败"
    info "透明代理规则已重载"
  else
    info "Service is not running，The configuration will take effect on the next startup"
  fi
}

cmd_app_list() {
  printf "分应用代理: %s\n" "$(read_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "0")"
  printf "应用模式: %s\n" "$(read_conf "$TPROXY_CONF" "APP_PROXY_MODE" "blacklist")"
  printf "代理列表: %s\n" "$(read_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "")"
  printf "绕过列表: %s\n" "$(read_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "")"
}

cmd_app_mode() {
  local mode="${1:-}"

  case "$mode" in
    blacklist | whitelist) ;;
    *) die_cli "用法: cli app mode <blacklist|whitelist>" ;;
  esac

  set_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "1"
  set_conf "$TPROXY_CONF" "APP_PROXY_MODE" "$(quote_conf "$mode")"
  info "应用模式已设置为: $mode"
  reload_tproxy_if_running
}

cmd_app_add() {
  local package="${1:-}"
  local mode current_list new_list

  [ -n "$package" ] || die_cli "用法: cli app add <包名>"

  set_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "1"
  mode="$(read_conf "$TPROXY_CONF" "APP_PROXY_MODE" "blacklist")"

  if [ "$mode" = "whitelist" ]; then
    current_list="$(read_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "")"
    new_list="$(list_add "$current_list" "$package")"
    set_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "$(quote_conf "$new_list")"
  else
    current_list="$(read_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "")"
    new_list="$(list_add "$current_list" "$package")"
    set_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "$(quote_conf "$new_list")"
  fi

  info "已添加应用: $package"
  reload_tproxy_if_running
}

cmd_app_remove() {
  local package="${1:-}"
  local proxy_list bypass_list

  [ -n "$package" ] || die_cli "用法: cli app remove <包名>"

  proxy_list="$(list_remove "$(read_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "")" "$package")"
  bypass_list="$(list_remove "$(read_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "")" "$package")"
  set_conf "$TPROXY_CONF" "PROXY_APPS_LIST" "$(quote_conf "$proxy_list")"
  set_conf "$TPROXY_CONF" "BYPASS_APPS_LIST" "$(quote_conf "$bypass_list")"

  info "已移除应用: $package"
  reload_tproxy_if_running
}

cmd_app_enable() {
  set_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "1"
  info "分应用代理已启用"
  reload_tproxy_if_running
}

cmd_app_disable() {
  set_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "0"
  info "分应用代理已禁用"
  reload_tproxy_if_running
}

cmd_app() {
  local subcmd="${1:-list}"
  shift 2> /dev/null || true

  case "$subcmd" in
    list) cmd_app_list "$@" ;;
    mode) cmd_app_mode "$@" ;;
    add) cmd_app_add "$@" ;;
    remove | rm) cmd_app_remove "$@" ;;
    enable) cmd_app_enable "$@" ;;
    disable) cmd_app_disable "$@" ;;
    help | -h | --help) show_app_help ;;
    *) die_cli "用法错误，使用 cli app help 查看帮助" ;;
  esac
}

#######################################
# tproxy 命令
#######################################
cmd_tproxy_status() {
  section "透明代理配置"
  printf "TCP 端口: %s\n" "$(read_conf "$TPROXY_CONF" "PROXY_TCP_PORT" "-")"
  printf "UDP 端口: %s\n" "$(read_conf "$TPROXY_CONF" "PROXY_UDP_PORT" "-")"
  printf "DNS 端口: %s\n" "$(read_conf "$TPROXY_CONF" "DNS_PORT" "-")"
  printf "代理模式: %s\n" "$(read_conf "$TPROXY_CONF" "PROXY_MODE" "0")"
  printf "分应用代理: %s\n" "$(read_conf "$TPROXY_CONF" "APP_PROXY_ENABLE" "0")"
  printf "阻断 QUIC: %s\n" "$(read_conf "$TPROXY_CONF" "BLOCK_QUIC" "0")"
  printf "绕过中国 IP: %s\n" "$(read_conf "$TPROXY_CONF" "BYPASS_CN_IP" "0")"
}

cmd_tproxy_reload() {
  reload_tproxy_if_running
}

cmd_tproxy_quic() {
  local value="${1:-}"

  case "$value" in
    on) set_conf "$TPROXY_CONF" "BLOCK_QUIC" "1" ;;
    off) set_conf "$TPROXY_CONF" "BLOCK_QUIC" "0" ;;
    *) die_cli "用法: cli tproxy quic <on|off>" ;;
  esac

  info "QUIC 设置已更新: $value"
  reload_tproxy_if_running
}

cmd_tproxy_cnip() {
  local value="${1:-}"

  case "$value" in
    on) set_conf "$TPROXY_CONF" "BYPASS_CN_IP" "1" ;;
    off) set_conf "$TPROXY_CONF" "BYPASS_CN_IP" "0" ;;
    *) die_cli "用法: cli tproxy cnip <on|off>" ;;
  esac

  info "中国 IP 绕过已更新: $value"
  reload_tproxy_if_running
}

cmd_tproxy() {
  local subcmd="${1:-status}"
  shift 2> /dev/null || true

  case "$subcmd" in
    status) cmd_tproxy_status "$@" ;;
    reload | restart) cmd_tproxy_reload "$@" ;;
    quic) cmd_tproxy_quic "$@" ;;
    cnip) cmd_tproxy_cnip "$@" ;;
    help | -h | --help) show_tproxy_help ;;
    *) die_cli "用法错误，使用 cli tproxy help 查看帮助" ;;
  esac
}

#######################################
# 总帮助
#######################################
show_help() {
  cat << EOF
NetProxy CLI

服务:
  cli service status                  查看服务状态
  cli service start                   启动服务
  cli service stop                    停止服务
  cli service restart                 重启服务
  cli service logs [service|core|sub] [行数]
                                      查看日志

节点:
  cli node list                       列出全部节点
  cli node current                    查看当前节点
  cli node use <名称|标签|路径>       切换节点
  cli node add <节点链接>             添加单个节点
  cli node import <文件>              导入节点文件或 Clash YAML
  cli node export <节点文件>          将 sing-box 节点转为链接
  cli node show <名称|标签|路径>      查看节点配置
  cli node remove <名称|标签|路径>    删除节点
  cli node delay [名称|标签|all]      测试节点延迟

模式:
  cli mode                            查看当前模式
  cli mode <rule|global|direct>       切换出站模式

订阅:
  cli sub list                        列出订阅
  cli sub add <名称> <链接>           添加订阅
  cli sub update <名称>               更新指定订阅
  cli sub update-all                  更新全部订阅
  cli sub remove <名称>               删除订阅

控制接口:
  cli api groups                      查看代理组
  cli api conns                       查看连接
  cli api close <连接ID>              关闭指定连接
  cli api close-all                   关闭全部连接
  cli api ui                          查看控制器与面板地址

分应用代理:
  cli app list                        查看分应用代理配置
  cli app mode <blacklist|whitelist>  设置分应用模式
  cli app add <包名>                  添加应用
  cli app remove <包名>               移除应用
  cli app enable                      启用分应用代理
  cli app disable                     禁用分应用代理

透明代理:
  cli tproxy status                   查看透明代理配置
  cli tproxy reload                   重载透明代理规则
  cli tproxy quic <on|off>            开关 QUIC 阻断
  cli tproxy cnip <on|off>            开关中国 IP 绕过
EOF
}

#######################################
# main entrance
#######################################
main() {
  local group="${1:-help}"
  shift 2> /dev/null || true

  ensure_cli_dirs

  case "$group" in
    service) cmd_service "$@" ;;
    node) cmd_node "$@" ;;
    mode) cmd_mode "$@" ;;
    sub) cmd_sub "$@" ;;
    api) cmd_api "$@" ;;
    app) cmd_app "$@" ;;
    tproxy) cmd_tproxy "$@" ;;
    help | -h | --help) show_help ;;
    *) die_cli "未知命令组: $group，使用 cli help 查看帮助" ;;
  esac
}

main "$@"
