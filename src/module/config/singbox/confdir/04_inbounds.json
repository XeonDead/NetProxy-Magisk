{
  "inbounds": [
//    {
//      "type": "mixed",
//      "tag": "mixed_in",
//      "listen": "::",
//      "listen_port": 7080
//    },
    {
      "type": "tproxy",
      "tag": "tproxy_in",
      "listen": "::",
      "listen_port": 1536,
    }
  ],
  "route": {
    "rules": [
      {
        "inbound": "tproxy_in",
        "action": "resolve",
        "strategy": "prefer_ipv4"
      },
      {
        "inbound": "tproxy_in",
        "action": "sniff",
        "timeout": "1s"
      }
    ]
  }
}
