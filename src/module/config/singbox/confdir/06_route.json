{
  "route": {
    "default_http_client": "default-http-client",
    "default_domain_resolver": "google",
    "rule_set": [
      {
        "tag": "block",
        "type": "local",
        "format": "source",
        "path": "./source/block.json"
      },
      {
        "tag": "direct",
        "type": "local",
        "format": "source",
        "path": "./source/direct.json"
      },
      {
        "tag": "proxy",
        "type": "local",
        "format": "source",
        "path": "./source/proxy.json"
      },
      {
        "tag": "geosite-category-ads",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/hydraponique/roscomvpn-geosite/release/sing-box/category-ads.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geosite-category-ads.srs"
      },
      {
        "tag": "geosite-whitelist",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/hydraponique/roscomvpn-geosite/release/sing-box/whitelist.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geosite-whitelist.srs"
      },
      {
        "tag": "geosite-category-ru",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/hydraponique/roscomvpn-geosite/release/sing-box/category-ru.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geosite-category-ru.srs"
      },
      {
        "tag": "geosite-category-geoblock-ru",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/hydraponique/roscomvpn-geosite/release/sing-box/category-geoblock-ru.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geosite-category-geoblock-ru.srs"
      },
      {
        "tag": "geosite-private",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/hydraponique/roscomvpn-geosite/release/sing-box/private.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geosite-private.srs"
      },
      {
        "tag": "geosite-torrent",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/hydraponique/roscomvpn-geosite/release/sing-box/torrent.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geosite-torrent.srs"
      },
      {
        "tag": "geoip-direct",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/hydraponique/roscomvpn-geoip/release/sing-box/direct.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geoip-direct.srs"
      },
      {
        "tag": "geoip-whitelist",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/hydraponique/roscomvpn-geoip/release/sing-box/whitelist.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geoip-whitelist.srs"
      },
      {
        "tag": "geoip-private",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/hydraponique/roscomvpn-geoip/release/sing-box/private.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geoip-private.srs"
      },
      {
        "tag": "f-droid-repos",
        "format": "domain_suffix",
        "rules": [
          {
            "domain_suffix": [
              "izzyondroid.org",
              "izzysoft.de",
              "futo.org",
              "guardianproject.info",
              "api.spaceidle.xyz"
            ]
          }
        ]
      },
      {
        "tag": "ai-proxy-suffix",
        "format": "domain_suffix",
        "rules": [
          {
            "domain_suffix": [
              "midjourney.com",
              "civitai.com"
            ]
          }
        ]
      }
    ],
    "rules": [
      {
        "action": "sniff-override-destination"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "port": 53
          },
          {
            "protocol": "dns"
          }
        ],
        "action": "hijack-dns"
      },
      {
        "ip_cidr": [
          "198.18.0.0/15",
          "fc00::/18"
        ],
        "action": "route",
        "outbound": "proxy"
      },
      {
        "rule_set": [
          "direct"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": [
          "proxy"
        ],
        "action": "route",
        "outbound": "proxy"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "clash_mode": "AllowAds",
            "invert": true
          },
          {
            "rule_set": [
              "block",
              "geosite-category-ads",
              "geosite-torrent"
            ]
          }
        ],
        "action": "reject",
        "rcode": "success"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "domain_suffix": [
          "local",
          "lan"
        ],
        "outbound": "direct-out"
      },
      {
        "action": "resolve",
        "match_only": true,
        "strategy": "ipv4_only",
        "server": "alidns"
      },
      {
        "rule_set": [
          "geosite-category-geoblock-ru",
          "ai-proxy-suffix",
          "f-droid-repos"
        ],
        "action": "route",
        "outbound": "proxy"
      },
      {
        "rule_set": [
          "geosite-whitelist",
          "geosite-private".
          "geoip-whitelist",
          "geoip-private",
          "geosite-category-ru",
          "geoip-direct"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "protocol": [
          "bittorrent"
        ],
        "outbound": "direct"
      }
    ],
    "find_process": true,
    "final": "direct"
  }
}