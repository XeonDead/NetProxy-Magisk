{
  "route": {
    "default_http_client": "default-http-client",
    "default_domain_resolver": "malwlink",
    "rule_set": [
      {
        "tag": "block",
        "type": "local",
        "format": "source",
        "path": "./source/block.json"
      },
      {
        "tag": "direct",
        "type": "local",
        "format": "source",
        "path": "./source/direct.json"
      },
      {
        "tag": "proxy",
        "type": "local",
        "format": "source",
        "path": "./source/proxy.json"
      },
      {
        "tag": "category-ads-all",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/CHIZI-0618/v2ray-rules-dat/release/singbox_rule_set/geosite-category-ads-all.srs",
        "http_client": "default-http-client",
        "update_interval": "24h",
        "path": "./source/category-ads-all.srs"
      },
      {
        "tag": "ru-blocked-ip",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geoip/geoip-ru-blocked.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geoip-ru-blocked.srs"
      },
      {
        "tag": "ru-blocked-ip-community",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geoip/geoip-ru-blocked-community.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geoip-ru-blocked-community.srs"
      },
      {
        "tag": "ru-blocked-site",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-ru-blocked-all.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geosite-ru-blocked-all.srs"
      },
      {
        "tag": "geo-ads-all",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-category-ads-all.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geosite-category-ads-all.srs"
      },
      {
        "tag": "ru-available-only-inside",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-ru-available-only-inside.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geosite-ru-available-only-inside.srs"
      },
      {
        "tag": "ru-re-filter-geoip",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geoip/geoip-re-filter.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geoip-refilter.srs"
      },
      {
        "tag": "ru-re-filter-geosite",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-refilter.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geosite-refilter.srs"
      },
      {
        "tag": "geosite-category-dev",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-category-dev.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geosite-category-dev.srs"
      },
      {
        "tag": "geosite-category-ai-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-category-ai-cn.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geosite-category-ai-cn.srs"
      },
      {
        "tag": "geosite-category-ai-!cn",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-category-ai-!cn.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geosite-category-ai-!cn.srs"
      },
      {
        "tag": "geosite-f-droid",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-f-droid.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/geosite-f-droid.srs"
      },
      {
        "tag": "blocked-russia-int-ext-sites",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/itdoginfo/allow-domains/releases/latest/download/russia_inside.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/blocked-russia-int-ext-sites.srs"
      },
      {
        "tag": "inside-russia-from-outside",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/itdoginfo/allow-domains/releases/latest/download/russia_outside.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/inside-russia-from-outside.srs"
      },
      {
        "tag": "telegram",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/itdoginfo/allow-domains/releases/latest/download/telegram.srs",
        "http_client": "default-http-client",
        "update_interval": "6h",
        "path": "./source/telegram.srs"
      },
      {
        "tag": "f-droid-repos",
        "format": "domain_suffix",
        "rules": [
          {
            "domain_suffix": [
              "izzyondroid.org",
              "izzysoft.de",
              "futo.org",
              "guardianproject.info",
              "api.spaceidle.xyz"
            ]
          }
        ]
      },
      {
        "tag": "ai-proxy-suffix",
        "format": "domain_suffix",
        "rules": [
          {
            "domain_suffix": [
              "midjourney.com",
              "civitai.com"
            ]
          }
        ]
      }
    ],
    "rules": [
      {
        "action": "sniff-override-destination"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "port": 53
          },
          {
            "protocol": "dns"
          }
        ],
        "action": "hijack-dns"
      },
      {
        "ip_cidr": [
          "198.18.0.0/15",
          "fc00::/18"
        ],
        "action": "route",
        "outbound": "proxy"
      },
      {
        "rule_set": [
          "direct"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": [
          "proxy"
        ],
        "action": "route",
        "outbound": "proxy"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "clash_mode": "AllowAds",
            "invert": true
          },
          {
            "rule_set": [
              "block",
              "category-ads-all",
              "geo-ads-all"
            ]
          }
        ],
        "action": "reject"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "domain_suffix": [
          "local",
          "lan"
        ],
        "outbound": "direct-out"
      },
      {
        "action": "resolve",
        "match_only": true,
        "strategy": "ipv4_only",
        "server": "malwlink"
      },
      {
        "rule_set": [
          "ru-blocked-ip",
          "ru-blocked-ip-community",
          "ru-blocked-site",
          "ru-re-filter-geoip",
          "ru-re-filter-geosite",
          "geosite-category-dev",
          "geosite-category-ai-cn",
          "geosite-category-ai-!cn",
          "geosite-f-droid",
          "blocked-russia-int-ext-sites",
          "telegram",
          "ai-proxy-suffix",
          "f-droid-repos"
        ],
        "action": "route",
        "outbound": "proxy"
      },
      {
        "rule_set": [
          "ru-available-only-inside",
          "inside-russia-from-outside"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "protocol": [
          "bittorrent"
        ],
        "outbound": "direct"
      }
    ],
    "find_process": true,
    "final": "direct"
  }
}