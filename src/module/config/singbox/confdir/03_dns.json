{
  "dns": {
    "servers": [
      {
        "tag": "malwlink",
        "type": "udp",
        "server": "193.23.209.189"
      },
      {
        "tag": "malwlink-cf",
        "type": "https",
        "server": "5u35p8m9i7.cloudflare-gateway.com",
        "detour": "proxy"
      },
      {
        "tag": "remote",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "clash_mode": "Direct",
        "action": "route",
        "server": "malwlink"
      },
      {
        "clash_mode": "Global",
        "action": "route",
        "server": "remote"
      },
      {
        "rule_set": [
          "direct"
        ],
        "action": "route",
        "server": "malwlink"
      },
      {
        "rule_set": [
          "proxy"
        ],
        "action": "route",
        "server": "remote"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "clash_mode": "AllowAds",
            "invert": true
          },
          {
            "rule_set": [
              "block",
              "category-ads-all",
              "geo-ads-all"
            ]
          }
        ],
        "action": "reject"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "action": "route",
        "server": "remote"
      }
    ],
    "strategy": "ipv4_only"
  }
}
