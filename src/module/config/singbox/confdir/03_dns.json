{
  "dns": {
    "servers": [
      {
        "tag": "adguard",
        "type": "udp",
        "server": "94.140.14.14"
      },
      {
        "tag": "malwlink-cf",
        "type": "https",
        "server": "5u35p8m9i7.cloudflare-gateway.com",
        "detour": "proxy"
      },
      {
        "tag": "remote",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      },
      {
        "tag": "malw-hosts",
        "type": "hosts",
        "path": [
          "./source/malw-dns.hosts"
        ]
      }
    ],
    "rules": [
      {
        "action": "evaluate",
        "server": "malw-hosts"
      },
      {
        "match_response": true,
        "ip_accept_any": true,
        "action": "respond"
      },
      {
        "clash_mode": "Direct",
        "action": "route",
        "server": "adguard"
      },
      {
        "clash_mode": "Global",
        "action": "route",
        "server": "remote"
      },
      {
        "rule_set": [
          "direct"
        ],
        "action": "route",
        "server": "adguard"
      },
      {
        "rule_set": [
          "proxy"
        ],
        "action": "route",
        "server": "remote"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "clash_mode": "AllowAds",
            "invert": true
          },
          {
            "rule_set": [
              "block",
              "category-ads-all",
              "geo-ads-all"
            ]
          }
        ],
        "action": "reject"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "action": "route",
        "server": "remote"
      }
    ],
    "strategy": "ipv4_only"
  }
}
